# Build output (compiled app binaries live at repo root)
/gdemugui.qt5.bin
/gdemugui.qt5.debug
/gdemugui.gtk2.bin
/gdemugui.gtk2.debug

# Lazarus / FPC intermediate artifacts
**/lib/*
*.ppu
*.o
*.or
*.compiled
*.pyc

# Editor / IDE local state
src/gdemugui.lps

# Build/IDE artifacts regenerados a cada build (logs do VSCode, i18n, resource).
# .lpi e .lfm seguem tracked (são o projeto/form de verdade).
.vscode/*.log
languages/*.pot
src/*.lrj
src/gdemugui.res

# Runtime-generated data (NOT the data/ assets, which are tracked)
temp/*
cache/*
library.json

# Packaged releases (rebuilt from source)
[rR]eleases

# External helper binaries — fetched on demand by scripts/fetch-tools.sh from the
# 'tools-v1' GitHub release, no longer stored in git (Linux x86-64, ~770 KB).
/tools/genisoimage
/tools/cdi4dc
/tools/cdirip

# Backups
**/backup/**

# Large dummy payload regenerated by the OpenBOR/DC tools
data/dcevo/000DUMMY.DAT
data/dcevo/ffmpeg2pass-0.log

# Keep boot-sector and image assets under data/ tracked even if patterns above broaden.
!data/**/*.BIN
!data/**/IP.BIN
!data/ip.bin
!data/**/*.png
!data/**/*.JPG
